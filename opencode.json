{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "taskit_add_attachment": "allow",
    "taskit_add_comment": "allow",
    "mobile_click_on_screen_at_coordinates": "allow",
    "mobile_drag_on_screen": "allow",
    "mobile_find_and_click_element": "allow",
    "mobile_get_element_tree": "allow",
    "mobile_get_screen_size": "allow",
    "mobile_install_app": "allow",
    "mobile_launch_app": "allow",
    "mobile_list_available_devices": "allow",
    "mobile_long_press_on_screen_at_coordinates": "allow",
    "mobile_navigate_back": "allow",
    "mobile_open_url": "allow",
    "mobile_save_screenshot": "allow",
    "mobile_scroll_down": "allow",
    "mobile_scroll_up": "allow",
    "mobile_set_screen_brightness": "allow",
    "mobile_swipe_on_screen": "allow",
    "mobile_terminate_app": "allow",
    "mobile_type_keys": "allow",
    "mobile_wait": "allow",
    "click": "allow",
    "close_page": "allow",
    "drag": "allow",
    "emulate": "allow",
    "evaluate_script": "allow",
    "fill": "allow",
    "fill_form": "allow",
    "get_console_message": "allow",
    "get_network_request": "allow",
    "handle_dialog": "allow",
    "hover": "allow",
    "list_console_messages": "allow",
    "list_network_requests": "allow",
    "list_pages": "allow",
    "navigate_page": "allow",
    "new_page": "allow",
    "performance_analyze_insight": "allow",
    "performance_start_trace": "allow",
    "performance_stop_trace": "allow",
    "press_key": "allow",
    "resize_page": "allow",
    "select_page": "allow",
    "take_memory_snapshot": "allow",
    "take_screenshot": "allow",
    "take_snapshot": "allow",
    "type_text": "allow",
    "upload_file": "allow",
    "wait_for": "allow"
  },
  "mcp": {
    "taskit": {
      "type": "local",
      "command": [
        "taskit-mcp"
      ],
      "environment": {
        "TASKIT_URL": "http://localhost:9100"
      }
    },
    "mobile": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@mobilenext/mobile-mcp@latest"
      ]
    },
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest"
      ]
    }
  }
}
